<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.FuwujiluDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.FuwujiluEntity" id="fuwujiluMap">
        <result property="yuyuebianhao" column="yuyuebianhao"/>
        <result property="xiangmubianhao" column="xiangmubianhao"/>
        <result property="xiangmumingcheng" column="xiangmumingcheng"/>
        <result property="yuangongzhanghao" column="yuangongzhanghao"/>
        <result property="yuangongxingming" column="yuangongxingming"/>
        <result property="fuwuleixing" column="fuwuleixing"/>
        <result property="fuwufeiyong" column="fuwufeiyong"/>
        <result property="yonghuzhanghao" column="yonghuzhanghao"/>
        <result property="yonghuxingming" column="yonghuxingming"/>
        <result property="shoujihao" column="shoujihao"/>
        <result property="fuwushijian" column="fuwushijian"/>
        <result property="fuwuqueren" column="fuwuqueren"/>
        <result property="fuwutupian" column="fuwutupian"/>
        <result property="fuwujilu" column="fuwujilu"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.FuwujiluVO" >
		SELECT * FROM fuwujilu  fuwujilu         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.FuwujiluVO" >
		SELECT  fuwujilu.* FROM fuwujilu  fuwujilu 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.FuwujiluView" >

		SELECT  fuwujilu.* FROM fuwujilu  fuwujilu 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListViewCount" resultType="java.lang.Long" >

        SELECT  COUNT(1) FROM fuwujilu  fuwujilu 	
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>
	
	<select id="selectView"
		resultType="com.entity.view.FuwujiluView" >
		SELECT * FROM fuwujilu  fuwujilu <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM fuwujilu
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>


</mapper>
